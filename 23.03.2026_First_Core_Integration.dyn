    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "Id": "ea15fc4e0cb442ad9e866f2e0da09896",
      "NodeType": "FunctionNode",
      "Inputs": [
        {
          "Id": "53a3aa6407dc4bcf80b65f70934b47f7",
          "Name": "point",
          "Description": "Autodesk.DesignScript.Geometry.Point",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "7fe0c1ed92eb478988b5d3d184a5463f",
          "Name": "vectorToAdd",
          "Description": "Vector",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "f52c75101ad34b3fa87ac7295fb42aa0",
          "Name": "Point",
          "Description": "Point",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "FunctionSignature": "Autodesk.DesignScript.Geometry.Point.Add@Autodesk.DesignScript.Geometry.Vector",
      "Replication": "Auto",
      "Description": "Add a vector to a point. The same as Translate(Vector).\n\nPoint.Add (vectorToAdd: Vector): Point"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point\r\n\r\ndef item(x):\r\n    while isinstance(x, list):\r\n        if len(x) == 0:\r\n            return None\r\n        x = x[0]\r\n    return x\r\n\r\ndef to_num(x):\r\n    x = item(x)\r\n    if isinstance(x, str):\r\n        x = x.strip()\r\n    return float(x)\r\n\r\nP1 = item(IN[0])   # Object 1 point\r\nP2 = item(IN[1])   # Object 2 point\r\nb1 = to_num(IN[2]) # Width 1\r\nb2 = to_num(IN[3]) # Width 2\r\nX  = item(IN[4])   # LocalX normalized vector\r\n\r\nnewP1 = P1\r\nnewP2 = P2\r\n\r\nif b1 > b2:\r\n    # Object 1 is bigger -> move object 2 in +LocalX\r\n    d = (b1 - b2) / 2.0\r\n    newP2 = Point.ByCoordinates(\r\n        P2.X + X.X * d,\r\n        P2.Y + X.Y * d,\r\n        P2.Z + X.Z * d\r\n    )\r\n\r\nelif b2 > b1:\r\n    # Object 2 is bigger -> move object 1 in +LocalX\r\n    d = (b2 - b1) / 2.0\r\n    newP1 = Point.ByCoordinates(\r\n        P1.X + X.X * d,\r\n        P1.Y + X.Y * d,\r\n        P1.Z + X.Z * d\r\n    )\r\n\r\nOUT = [newP1, newP2]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "1e5bdb2956854751bb92052189a19085",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "f2dd704741b44d459d168fb66c1ce06a",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
