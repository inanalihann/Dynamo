        }
      ],
      "FunctionSignature": "Autodesk.DesignScript.Geometry.Vector.Scale@double",
      "Replication": "Auto",
      "Description": "Scale Vector uniformly around the origin\n\nVector.Scale (scale_factor: double = 1): Vector"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nfrom System.Collections.Generic import List\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nelements = UnwrapElement(IN[0])\r\nbase_vector = IN[1]\r\nrepeat = int(IN[2])\r\n\r\nif not isinstance(elements, list):\r\n    elements = [elements]\r\n\r\n# if vector comes as [vector], take first item\r\nif isinstance(base_vector, list):\r\n    base_vector = base_vector[0]\r\n\r\ncopies = repeat - 1\r\nif copies < 0:\r\n    copies = 0\r\n\r\nids = List[ElementId]([e.Id for e in elements])\r\n\r\nout = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor i in range(1, copies + 1):\r\n    move = XYZ(base_vector.X * i, base_vector.Y * i, base_vector.Z * i)\r\n    newIds = ElementTransformUtils.CopyElements(doc, ids, move)\r\n    out.append([doc.GetElement(x) for x in newIds])\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = out",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "5d933f3364b4463d8427648bd8f43181",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "59189b84086e48b38ac293dcad7c1055",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "31f1a4b316084477ba4efe5bf092ea3e",
