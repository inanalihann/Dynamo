    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Vector, CoordinateSystem\r\n\r\ndef first(x):\r\n    while isinstance(x, list) and len(x) == 1:\r\n        x = x[0]\r\n    return x\r\n\r\norigin = first(IN[0])\r\nux = first(IN[1])\r\ng = first(IN[2])\r\n\r\nux_len = (ux.X**2 + ux.Y**2) ** 0.5\r\n\r\nif ux_len == 0:\r\n    OUT = \"Error: local X vector length is zero.\"\r\nelse:\r\n    localX = Vector.ByCoordinates(ux.X / ux_len, ux.Y / ux_len, 0)\r\n\r\n    # build perpendicular local Y\r\n    yx = -localX.Y\r\n    yy =  localX.X\r\n\r\n    # flip with guide direction\r\n    dot = yx * g.X + yy * g.Y\r\n    if dot < 0:\r\n        yx = -yx\r\n        yy = -yy\r\n\r\n    localY = Vector.ByCoordinates(yx, yy, 0)\r\n    localZ = Vector.ByCoordinates(0, 0, 1)\r\n\r\n    cs = CoordinateSystem.ByOriginVectors(origin, localX, localY)\r\n\r\n    OUT = origin, localX, localY, localZ, cs",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "b70c824c3aef41e781c59971922ad4a2",
      "NodeType": "PythonScriptNode",
