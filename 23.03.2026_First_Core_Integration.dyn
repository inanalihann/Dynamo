    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python Node\r\n# Inputs: IN[0]=O, IN[1]=P1, IN[2]=P2, IN[3]=X, IN[4]=Y,\r\n#         IN[5]=dMin, IN[6]=L2, IN[7]=L1\r\n\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Vector\r\n\r\n# ── helpers ───────────────────────────────────────────────────────────────────\r\n\r\ndef unwrap(val):\r\n    while isinstance(val, (list, tuple)) and len(val) == 1:\r\n        val = val[0]\r\n    return val\r\n\r\ndef to_xy(obj):\r\n    obj = unwrap(obj)\r\n    if hasattr(obj, 'X') and hasattr(obj, 'Y'):\r\n        return (float(obj.X), float(obj.Y))\r\n    return (float(obj[0]), float(obj[1]))\r\n\r\ndef norm2(v):\r\n    x, y = v\r\n    mag = (x*x + y*y) ** 0.5\r\n    if mag < 1e-12:\r\n        raise ValueError(\"Zero-length vector.\")\r\n    return (x / mag, y / mag)\r\n\r\ndef cross2(a, b):\r\n    return a[0]*b[1] - a[1]*b[0]\r\n\r\ndef dot2(a, b):\r\n    return a[0]*b[0] + a[1]*b[1]\r\n\r\ndef add2(p, v):\r\n    return (p[0]+v[0], p[1]+v[1])\r\n\r\ndef scale2(v, s):\r\n    return (v[0]*s, v[1]*s)\r\n\r\ndef sub2(a, b):\r\n    return (a[0]-b[0], a[1]-b[1])\r\n\r\ndef to_point(xy, z=0.0):\r\n    return Point.ByCoordinates(xy[0], xy[1], z)\r\n\r\n# ── read inputs ───────────────────────────────────────────────────────────────\r\n\r\nO_raw  = unwrap(IN[0])\r\nP1_raw = unwrap(IN[1])\r\nP2_raw = unwrap(IN[2])\r\nX_raw  = unwrap(IN[3])\r\nY_raw  = unwrap(IN[4])\r\ndMin   = float(unwrap(IN[5]))\r\nL2     = float(unwrap(IN[6]))\r\nL1     = float(unwrap(IN[7]))\r\n\r\ntry:\r\n    z_P1 = float(P1_raw.Z)\r\n    z_P2 = float(P2_raw.Z)\r\nexcept AttributeError:\r\n    z_P1 = 0.0\r\n    z_P2 = 0.0\r\n\r\nO  = to_xy(O_raw)\r\nP1 = to_xy(P1_raw)\r\nP2 = to_xy(P2_raw)\r\n\r\n# ── Step 1–2: normalize, compute perp(X) ─────────────────────────────────────\r\n\r\nXhat = norm2(to_xy(X_raw))\r\nYhat = norm2(to_xy(Y_raw))\r\n\r\nperp_ccw = (-Xhat[1],  Xhat[0])\r\nperp_cw  = ( Xhat[1], -Xhat[0])\r\n\r\n# ── Step 3: orient perp(X) consistent with Y ─────────────────────────────────\r\n\r\nperpX = perp_ccw if dot2(perp_ccw, Yhat) >= 0.0 else perp_cw\r\n\r\n# ── Step 4: four object points ────────────────────────────────────────────────\r\n\r\nP1_end = add2(P1, scale2(perpX, L1))\r\nP2_end = add2(P2, scale2(perpX, L2))\r\n\r\n# ── Step 5: signed perpendicular distances to Y-line through O ───────────────\r\n# s = cross(P - O, Yhat)\r\n\r\ndef sdist(P):\r\n    return cross2(sub2(P, O), Yhat)\r\n\r\ns_P1    = sdist(P1)\r\ns_P1end = sdist(P1_end)\r\ns_P2    = sdist(P2)\r\ns_P2end = sdist(P2_end)\r\n\r\nsigned_dists = [s_P1, s_P1end, s_P2, s_P2end]\r\n\r\n# ── Step 6: translation t along X ────────────────────────────────────────────\r\n#\r\n# Moving P by t*Xhat changes its signed distance by:\r\n#   delta_s = cross(Xhat, Yhat)\r\n#\r\n# VALID SIDE: derived purely from the direction vectors, not from where the\r\n# points currently sit.  The objects live on the side that Xhat \"points toward\"\r\n# relative to the Y-line.\r\n#\r\n#   delta_s > 0  →  +X increases signed dist  →  valid side is positive (+1)\r\n#   delta_s < 0  →  +X decreases signed dist  →  valid side is negative (-1)\r\n#\r\n# This is unambiguous for any angle between X and Y (acute or obtuse).\r\n\r\ndelta_s = cross2(Xhat, Yhat)\r\n\r\nif abs(delta_s) < 1e-12:\r\n    # X parallel to Y — movement along X cannot change perp distance\r\n    OUT = [P1_raw, P2_raw]\r\nelse:\r\n    # Valid side: the sign that moving in +X pushes points toward\r\n    valid_sign = 1 if delta_s > 0 else -1\r\n\r\n    # Target signed distance (positive or negative dMin on the valid side)\r\n    target = dMin * valid_sign\r\n\r\n    # Required t for each point to reach exactly the target boundary:\r\n    #   s(P) + t * delta_s = target  →  t = (target - s) / delta_s\r\n    t_candidates = [(target - s) / delta_s for s in signed_dists]\r\n\r\n    # We need ALL points to be at or beyond dMin on the valid side.\r\n    # The binding constraint is the point requiring the most movement.\r\n    #\r\n    # When valid_sign > 0 (positive side):\r\n    #   We need s_new >= dMin  →  t >= (dMin - s) / delta_s\r\n    #   The largest t_candidate satisfies all constraints simultaneously.\r\n    #\r\n    # When valid_sign < 0 (negative side):\r\n    #   We need s_new <= -dMin  →  t <= (-dMin - s) / delta_s\r\n    #   The smallest (most negative) t_candidate is the binding one.\r\n    #\r\n    # In both cases: pick max if delta_s > 0, min if delta_s < 0.\r\n    # (This is equivalent to: the t that moves the closest point to exactly dMin.)\r\n\r\n    if delta_s > 0:\r\n        t = max(t_candidates)\r\n    else:\r\n        t = min(t_candidates)\r\n\r\n    # ── Step 7: apply translation ─────────────────────────────────────────────\r\n\r\n    shift = scale2(Xhat, t)\r\n    newP1 = to_point(add2(P1, shift), z_P1)\r\n    newP2 = to_point(add2(P2, shift), z_P2)\r\n\r\n    OUT = [newP1, newP2]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "ce02e43eceee4e0a8690662d35491fdc",
      "NodeType": "PythonScriptNode",
      "Inputs": [
