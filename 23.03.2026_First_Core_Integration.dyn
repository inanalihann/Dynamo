    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Vector\r\n\r\nvs = IN[0]   # main vector or list of vectors\r\ngs = IN[1]   # guide vector or list of vectors\r\n\r\ndef to_list(x):\r\n    return x if isinstance(x, list) else [x]\r\n\r\nvs = to_list(vs)\r\ngs = to_list(gs)\r\n\r\n# if one guide vector is given, repeat it for all main vectors\r\nif len(gs) == 1 and len(vs) > 1:\r\n    gs = gs * len(vs)\r\n\r\nout = []\r\n\r\nfor v, g in zip(vs, gs):\r\n    if v is None or g is None:\r\n        out.append(None)\r\n        continue\r\n\r\n    x = v.X\r\n    y = v.Y\r\n\r\n    # perpendicular in XY\r\n    px = -y\r\n    py = x\r\n\r\n    # choose side from guide vector\r\n    dot = px * g.X + py * g.Y\r\n\r\n    if dot < 0:\r\n        px = -px\r\n        py = -py\r\n\r\n    out.append(Vector.ByCoordinates(px, py, 0))\r\n\r\nOUT = out",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "6bdf9448cc0649c9b50e441c6071c10d",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "baae3e6861bc4496b25fee709ff88e0e",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
