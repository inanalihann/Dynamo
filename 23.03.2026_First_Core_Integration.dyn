    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport math\r\nclr.AddReference('ProtoGeometry')\r\nimport Autodesk.DesignScript.Geometry as DSGeo\r\n\r\ndef unwrap(x):\r\n    while isinstance(x, (list, tuple)) and len(x) == 1:\r\n        x = x[0]\r\n    return x\r\n\r\nprev          = IN[0]\r\nsys_curves_r1 = prev[2]\r\nsys_curves_r2 = prev[3]\r\ninfo_dict     = prev[11]\r\ncableDia_m    = float(info_dict[\"cableDia_m\"])\r\n\r\nsin60  = math.sqrt(3) / 2.0\r\nr      = cableDia_m / 2.0\r\nhalf_d = cableDia_m / 2.0\r\n\r\ntrefoil_offsets = [\r\n    (-half_d, 0.0              ),\r\n    ( half_d, 0.0              ),\r\n    ( 0.0,    cableDia_m*sin60 ),\r\n]\r\n\r\ndef get_right_vec(curves):\r\n    for c in curves:\r\n        if c is None:\r\n            continue\r\n        try:\r\n            tan = c.TangentAtParameter(0.5)\r\n            tan_h = DSGeo.Vector.ByCoordinates(tan.X, tan.Y, 0)\r\n            if tan_h.Length > 0.01:\r\n                tan_h = tan_h.Normalized()\r\n                world_z = DSGeo.Vector.ByCoordinates(0, 0, 1)\r\n                rv = world_z.Cross(tan_h).Normalized()\r\n                if rv.Length > 0.01:\r\n                    return rv\r\n        except:\r\n            continue\r\n    return DSGeo.Vector.ByCoordinates(1, 0, 0)\r\n\r\ndef try_sweep(profile, path):\r\n    \"\"\"Try multiple sweep methods, return first that works.\"\"\"\r\n    # method 1: direct BySweep\r\n    try:\r\n        s = DSGeo.Solid.BySweep(profile, path)\r\n        if s is not None:\r\n            return s, \"BySweep\"\r\n    except:\r\n        pass\r\n\r\n    # method 2: convert curve to polycurve first\r\n    try:\r\n        pts = [path.PointAtParameter(i/20.0) for i in range(21)]\r\n        # build lines between consecutive points\r\n        lines = []\r\n        for i in range(len(pts)-1):\r\n            try:\r\n                l = DSGeo.Line.ByStartPointEndPoint(pts[i], pts[i+1])\r\n                lines.append(l)\r\n            except:\r\n                pass\r\n        if lines:\r\n            pc = DSGeo.PolyCurve.ByJoinedCurves(lines)\r\n            s = DSGeo.Solid.BySweep(profile, pc)\r\n            if s is not None:\r\n                return s, \"BySweep+PolyCurve\"\r\n    except:\r\n        pass\r\n\r\n    # method 3: pipe (cylinder along path)\r\n    try:\r\n        s = DSGeo.Solid.BySweep(profile, path, False)\r\n        if s is not None:\r\n            return s, \"BySweep+open\"\r\n    except:\r\n        pass\r\n\r\n    return None, \"all_failed\"\r\n\r\ndef make_trefoil_sweep(curve, right_vec):\r\n    errors = []\r\n    trio   = []\r\n    up_vec = DSGeo.Vector.ByCoordinates(0, 0, 1)\r\n\r\n    try:\r\n        start_pt = curve.StartPoint\r\n        tan      = curve.TangentAtParameter(\r\n                       curve.ParameterAtPoint(start_pt))\r\n        tan_vec  = DSGeo.Vector.ByCoordinates(\r\n                       tan.X, tan.Y, tan.Z).Normalized()\r\n\r\n        for (h, v) in trefoil_offsets:\r\n            center = DSGeo.Point.ByCoordinates(\r\n                start_pt.X + right_vec.X * h + up_vec.X * v,\r\n                start_pt.Y + right_vec.Y * h + up_vec.Y * v,\r\n                start_pt.Z + right_vec.Z * h + up_vec.Z * v\r\n            )\r\n            try:\r\n                circle = DSGeo.Circle.ByCenterPointRadiusNormal(\r\n                    center, r, tan_vec\r\n                )\r\n                solid, method = try_sweep(circle, curve)\r\n                trio.append(solid)\r\n                if solid is None:\r\n                    errors.append(\"all methods failed h={:.3f} v={:.3f}\".format(h, v))\r\n            except Exception as e:\r\n                errors.append(\"circle/sweep error: {}\".format(str(e)))\r\n                trio.append(None)\r\n\r\n    except Exception as e:\r\n        errors.append(\"setup fail: {}\".format(str(e)))\r\n        trio = [None, None, None]\r\n\r\n    return trio, errors\r\n\r\n# ── Run sweeps ────────────────────────────────────────────────────────────────\r\nall_errors = []\r\nsweeps_r1  = []\r\nsweeps_r2  = []\r\n\r\nright_vec_r1 = get_right_vec(sys_curves_r1)\r\nright_vec_r2 = get_right_vec(sys_curves_r2)\r\n\r\nfor curve in sys_curves_r1:\r\n    if curve is not None:\r\n        trio, errs = make_trefoil_sweep(curve, right_vec_r1)\r\n        sweeps_r1.append(trio)\r\n        all_errors.extend(errs)\r\n    else:\r\n        sweeps_r1.append([None, None, None])\r\n\r\nfor curve in sys_curves_r2:\r\n    if curve is not None:\r\n        trio, errs = make_trefoil_sweep(curve, right_vec_r2)\r\n        sweeps_r2.append(trio)\r\n        all_errors.extend(errs)\r\n    else:\r\n        sweeps_r2.append([None, None, None])\r\n\r\nflat_r1 = [s for trio in sweeps_r1 for s in trio if s is not None]\r\nflat_r2 = [s for trio in sweeps_r2 for s in trio if s is not None]\r\n\r\nOUT = (\r\n    flat_r1,\r\n    flat_r2,\r\n    sweeps_r1,\r\n    sweeps_r2,\r\n    all_errors,\r\n    {\r\n        \"numSweeps_r1\":  len(sweeps_r1),\r\n        \"numSweeps_r2\":  len(sweeps_r2),\r\n        \"numSolids_r1\":  len(flat_r1),\r\n        \"numSolids_r2\":  len(flat_r2),\r\n        \"numErrors\":     len(all_errors),\r\n        \"cableDia_m\":    round(cableDia_m, 4),\r\n        \"r_m\":           round(r,          4),\r\n        \"right_vec_r1\":  [round(right_vec_r1.X,3),\r\n                          round(right_vec_r1.Y,3),\r\n                          round(right_vec_r1.Z,3)],\r\n    }\r\n)",
