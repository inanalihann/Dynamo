    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Line, Vector\r\nimport math\r\n\r\ndef unwrap(x):\r\n    while isinstance(x, (list, tuple)) and len(x) == 1:\r\n        x = x[0]\r\n    return x\r\n\r\ndef to_pt(x):\r\n    x = unwrap(x)\r\n    if hasattr(x, 'X'):\r\n        return x\r\n    return Point.ByCoordinates(float(x[0]), float(x[1]), float(x[2]) if len(x) > 2 else 0.0)\r\n\r\ndef to_vec(x):\r\n    x = unwrap(x)\r\n    if hasattr(x, 'X'):\r\n        return x\r\n    return Vector.ByCoordinates(float(x[0]), float(x[1]), float(x[2]) if len(x) > 2 else 0.0)\r\n\r\ndef norm_xy(v):\r\n    l = (v.X**2 + v.Y**2) ** 0.5\r\n    if l < 1e-10:\r\n        return Vector.ByCoordinates(1, 0, 0)\r\n    return Vector.ByCoordinates(v.X/l, v.Y/l, 0)\r\n\r\ndef from_excel(x, idx=1):\r\n    \"\"\"Read value from Excel list at index, convert mm to m.\"\"\"\r\n    x = unwrap(x)\r\n    if isinstance(x, (list, tuple)):\r\n        x = x[idx] if len(x) > idx else x[0]\r\n    try:\r\n        return float(x) / 1000.0\r\n    except:\r\n        return 0.0\r\n\r\ndef move(pt, vec, dist):\r\n    return Point.ByCoordinates(\r\n        pt.X + vec.X * dist,\r\n        pt.Y + vec.Y * dist,\r\n        pt.Z + vec.Z * dist\r\n    )\r\n\r\ndef safe_line(a, b, tol=1e-6):\r\n    if abs(a.X-b.X) < tol and abs(a.Y-b.Y) < tol and abs(a.Z-b.Z) < tol:\r\n        return None\r\n    try:\r\n        return Line.ByStartPointEndPoint(a, b)\r\n    except:\r\n        return None\r\n\r\n# ── Inputs ────────────────────────────────────────────────────────────────────\r\n# IN[0]  = [mv1, mv2]          MV exit points\r\n# IN[1]  = [ss1, ss2]          SS entry points\r\n# IN[2]  = mvMeet              center meeting point MV side\r\n# IN[3]  = ssMeet              center meeting point SS side\r\n# IN[4]  = localX vector\r\n# IN[5]  = localY vector\r\n# IN[6]  = [label, mvLen_mm]   straight exit length MV\r\n# IN[7]  = [label, ssLen_mm]   straight exit length SS\r\n# IN[8]  = [label, rodBreite_mm]\r\n# IN[9]  = [label, cableDia_mm]\r\n# IN[10] = [label, extraAbstand_mm]\r\n\r\nmvPts = unwrap(IN[0])\r\nssPts = unwrap(IN[1])\r\nmv1   = to_pt(mvPts[0])\r\nmv2   = to_pt(mvPts[1])\r\nss1   = to_pt(ssPts[0])\r\nss2   = to_pt(ssPts[1])\r\n\r\nmvMeet = to_pt(unwrap(IN[2]))\r\nssMeet = to_pt(unwrap(IN[3]))\r\n\r\nlocalX = norm_xy(to_vec(unwrap(IN[4])))\r\nlocalY = norm_xy(to_vec(unwrap(IN[5])))\r\n\r\nmvLen        = abs(from_excel(IN[6],  idx=1))\r\nssLen        = abs(from_excel(IN[7],  idx=1))\r\nrodBreite    = abs(from_excel(IN[8],  idx=1))\r\ncableDia     = abs(from_excel(IN[9],  idx=1))\r\nextraAbstand = abs(from_excel(IN[10], idx=1))\r\n\r\n# ── Abstand calculation ───────────────────────────────────────────────────────\r\n# o°o trefoil: horizontal footprint = 2 × cableDia per system\r\nsysBreite = 2.0 * cableDia\r\n\r\n# rod/2 + sysBreite + extraAbstand + sysBreite + rod/2\r\nabstand = rodBreite/2.0 + sysBreite + extraAbstand + sysBreite + rodBreite/2.0\r\nhalf    = abstand / 2.0\r\n\r\n# ── Column X positions left/right of center ───────────────────────────────────\r\n# Route 1 = left  (-half in localX)\r\n# Route 2 = right (+half in localX)\r\n\r\n# At mvMeet level — T2 points, Z snapped to mvMeet.Z\r\nmv_r1 = Point.ByCoordinates(\r\n    mvMeet.X + localX.X * -half,\r\n    mvMeet.Y + localX.Y * -half,\r\n    mvMeet.Z                        # Z from mvMeet\r\n)\r\nmv_r2 = Point.ByCoordinates(\r\n    mvMeet.X + localX.X *  half,\r\n    mvMeet.Y + localX.Y *  half,\r\n    mvMeet.Z                        # Z from mvMeet\r\n)\r\n\r\n# At ssMeet level — T3 points, Z snapped to ssMeet.Z\r\nss_r1 = Point.ByCoordinates(\r\n    ssMeet.X + localX.X * -half,\r\n    ssMeet.Y + localX.Y * -half,\r\n    ssMeet.Z                        # Z from ssMeet\r\n)\r\nss_r2 = Point.ByCoordinates(\r\n    ssMeet.X + localX.X *  half,\r\n    ssMeet.Y + localX.Y *  half,\r\n    ssMeet.Z                        # Z from ssMeet\r\n)\r\n\r\n# ── Route 1 turn points ───────────────────────────────────────────────────────\r\n# T1: mv1 straight out in -localY by mvLen\r\nr1_T1 = move(mv1, localY, -mvLen)\r\n\r\n# T2: same Y/Z as T1, X snapped to route-1 column (mv_r1.X)\r\nr1_T2 = Point.ByCoordinates(mv_r1.X, mv_r1.Y, mvMeet.Z)\r\n\r\n# T3: route-1 column at ssMeet level (already computed as ss_r1)\r\nr1_T3 = ss_r1\r\n\r\n# T4: ss1 exits +localX by ssLen → ssStart1 is ssLen out from ss1\r\nssStart1 = move(ss1, localX, ssLen)\r\n# T4 is at ssStart1 X, but at ssMeet Z level\r\nr1_T4 = Point.ByCoordinates(ssStart1.X, ss_r1.Y, ssMeet.Z)\r\n\r\n# ── Route 2 turn points ───────────────────────────────────────────────────────\r\n# T1: mv2 straight out in -localY by mvLen\r\nr2_T1 = move(mv2, localY, -mvLen)\r\n\r\n# T2: X snapped to route-2 column (mv_r2), Z from mvMeet\r\nr2_T2 = Point.ByCoordinates(mv_r2.X, mv_r2.Y, mvMeet.Z)\r\n\r\n# T3: route-2 column at ssMeet level\r\nr2_T3 = ss_r2\r\n\r\n# T4: ss2 exits -localX by ssLen\r\nssStart2 = move(ss2, localX, -ssLen)\r\nr2_T4 = Point.ByCoordinates(ssStart2.X, ss_r2.Y, ssMeet.Z)\r\n\r\n# ── Build segments ────────────────────────────────────────────────────────────\r\ndef make_route(mvPt, T1, T2, T3, T4, ssStart, ssPt):\r\n    segs = [\r\n        safe_line(mvPt,    T1),       # exit MV in -localY (mvLen)\r\n        safe_line(T1,      T2),       # lateral ±localX to column\r\n        safe_line(T2,      T3),       # down through both meet levels\r\n        safe_line(T3,      T4),       # lateral ±localX toward SS\r\n        safe_line(T4,      ssStart),  # down to SS entry level\r\n        safe_line(ssStart, ssPt),     # ssLen into SS entry point\r\n    ]\r\n    return [s for s in segs if s is not None]\r\n\r\nr1 = make_route(mv1, r1_T1, r1_T2, r1_T3, r1_T4, ssStart1, ss1)\r\nr2 = make_route(mv2, r2_T1, r2_T2, r2_T3, r2_T4, ssStart2, ss2)\r\n\r\n# ── Output ────────────────────────────────────────────────────────────────────\r\n# r1_T2, r1_T3, r2_T2, r2_T3 are already computed above\r\n# groundZ taken from ssMeet (the lower meeting point)\r\ngroundZ = ssMeet.Z\r\nOUT = (\r\n    r1, r2, abstand,\r\n    r1_T2, r1_T3,\r\n    r2_T2, r2_T3,\r\n    localX, localY,\r\n    groundZ,\r\n    cableDia,\r\n    rodBreite,\r\n    ssMeet.Z,       # temporary debug — what number shows here?\r\n)\r\n\r\n#OUT = (\r\n#    r1, r2, abstand,    # [0] [1] [2]\r\n#    r1_T2, r1_T3,       # [3] [4]\r\n#    r2_T2, r2_T3,       # [5] [6]\r\n#    localX, localY,     # [7] [8]\r\n#    groundZ,            # [9]\r\n#    cableDia,           # [10]\r\n#    rodBreite,          # [11]\r\n#)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
