    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Vector\r\n\r\ndef first(x):\r\n    while isinstance(x, list) and len(x) == 1:\r\n        x = x[0]\r\n    return x\r\n\r\ndef excel_value(x):\r\n    x = first(x)\r\n    if isinstance(x, list) and len(x) > 1:\r\n        x = x[1]\r\n    try:\r\n        return float(x) / 1000.0\r\n    except:\r\n        return 0.0\r\n\r\nssMid   = first(IN[0])\r\nlocalY  = first(IN[1])\r\nsafe    = excel_value(IN[2])\r\nbend    = excel_value(IN[3])\r\nheightZ = excel_value(IN[4])\r\n\r\ndist = safe + bend\r\nmove = localY.Scale(dist)\r\n\r\ntmpPt = ssMid.Add(move)\r\nssMeetPt = Point.ByCoordinates(tmpPt.X, tmpPt.Y, heightZ)\r\n\r\nOUT = ssMeetPt",
