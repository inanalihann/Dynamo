    {
      "ConcreteType": "CoreNodeModels.Input.FileObject, CoreNodeModels",
      "Id": "d403a87713f341d0bf6917bd19ffe5a2",
      "NodeType": "ExtensionNode",
      "Inputs": [
        {
          "Id": "73050696c7c44b4383bfb762dfbcf9a8",
          "Name": "path",
          "Description": "Path to the file as string.",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "f73885a290144e2e81c05dda5abd0cf2",
          "Name": "file",
          "Description": "File object",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Creates a file object from the given path"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport os\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nfile = IN[0]\r\npath = file.FullName\r\n\r\n# family name from file name\r\nfamily_name = os.path.splitext(os.path.basename(path))[0]\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n# load family\r\ndoc.LoadFamily(path)\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\n# find loaded family in project\r\ncollector = FilteredElementCollector(doc).OfClass(Family)\r\nfamily = None\r\n\r\nfor f in collector:\r\n    if f.Name == family_name:\r\n        family = f\r\n        break\r\n\r\n# get first type\r\nsymbol = None\r\nif family:\r\n    symbol_ids = family.GetFamilySymbolIds()\r\n    if symbol_ids:\r\n        symbol = doc.GetElement(list(symbol_ids)[0])\r\n\r\nOUT = symbol",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "3c6e03b84f754e18bf802cc9a71eff17",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "df87d5424c6f4fb2955a22989807e360",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "748eb819a9e244e0910efa39d9e1d593",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "Id": "437a3fac45224cfba0f6964dbe249397",
      "NodeType": "FunctionNode",
      "Inputs": [
        {
          "Id": "4bad30e2adb14ba3b7c17763974d99b7",
          "Name": "familyType",
          "Description": "Family Type. Also called Family Symbol.\n\nFamilyType",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "128fc48480984c2e940f06196f358ddd",
          "Name": "point",
          "Description": "Point in meters.\n\nPoint",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "db1fe0417d6044c596040a5972feb3a5",
          "Name": "FamilyInstance",
          "Description": "FamilyInstance",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "FunctionSignature": "Revit.Elements.FamilyInstance.ByPoint@Revit.Elements.FamilyType,Autodesk.DesignScript.Geometry.Point",
      "Replication": "Auto",
      "Description": "Place a Revit FamilyInstance given the FamilyType (also known as the FamilySymbol in the Revit API) and its coordinates in world space\n\nFamilyInstance.ByPoint (familyType: FamilyType, point: Point): FamilyInstance"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport math\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndef first_item(x):\r\n    while isinstance(x, list):\r\n        if len(x) == 0:\r\n            return None\r\n        x = x[0]\r\n    return x\r\n\r\ninst = first_item(IN[0])\r\nxvec = first_item(IN[1])\r\n\r\ninst = UnwrapElement(inst)\r\n\r\nif inst is None or xvec is None:\r\n    OUT = \"Input is empty\"\r\nelse:\r\n    # build perpendicular vector from LocalX\r\n    # (+90° in XY plane)\r\n    px = -xvec.Y\r\n    py =  xvec.X\r\n\r\n    target_angle = math.atan2(py, px)\r\n\r\n    facing = inst.FacingOrientation\r\n    current_angle = math.atan2(facing.Y, facing.X)\r\n\r\n    delta = target_angle - current_angle\r\n\r\n    pt = inst.Location.Point\r\n    axis = Line.CreateBound(pt, XYZ(pt.X, pt.Y, pt.Z + 10))\r\n\r\n    TransactionManager.Instance.EnsureInTransaction(doc)\r\n    ElementTransformUtils.RotateElement(doc, inst.Id, axis, delta)\r\n    TransactionManager.Instance.TransactionTaskDone()\r\n\r\n    OUT = delta",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "71b1a1e37fae4faa979033c023be551f",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "c425c8a3d8814296ac5d2558ea6632b5",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
