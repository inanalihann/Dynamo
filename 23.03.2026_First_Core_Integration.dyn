      "FunctionSignature": "DSCore.List.GetItemAtIndex@var[]..[],int",
      "Replication": "Auto",
      "Description": "Returns an item from the given list that's located at the specified index.\n\nList.GetItemAtIndex (list: var[]..[], index: int): var[]..[]"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport math\r\nclr.AddReference('ProtoGeometry')\r\nimport Autodesk.DesignScript.Geometry as DSGeo\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndef unwrap(x):\r\n    while isinstance(x, (list, tuple)) and len(x) == 1:\r\n        x = x[0]\r\n    return x\r\n\r\ndef to_int_idx(x, idx=1):\r\n    x = unwrap(x)\r\n    if isinstance(x, (list, tuple)):\r\n        x = x[idx] if len(x) > idx else x[0]\r\n    try:\r\n        return int(float(x))\r\n    except:\r\n        return 0\r\n\r\ndef from_excel(x, idx=1):\r\n    x = unwrap(x)\r\n    if isinstance(x, (list, tuple)):\r\n        x = x[idx] if len(x) > idx else x[0]\r\n    try:\r\n        return float(x) / 1000.0\r\n    except:\r\n        return 0.0\r\n\r\ndef to_pt(x):\r\n    x = unwrap(x)\r\n    if hasattr(x, 'X'):\r\n        return x\r\n    return DSGeo.Point.ByCoordinates(\r\n        float(x[0]), float(x[1]),\r\n        float(x[2]) if len(x) > 2 else 0.0\r\n    )\r\n\r\ndef to_vec(x):\r\n    x = unwrap(x)\r\n    if hasattr(x, 'X'):\r\n        return x\r\n    return DSGeo.Vector.ByCoordinates(float(x[0]), float(x[1]), 0.0)\r\n\r\ndef norm_xy(v):\r\n    l = (v.X**2 + v.Y**2) ** 0.5\r\n    if l < 1e-10:\r\n        return DSGeo.Vector.ByCoordinates(1, 0, 0)\r\n    return DSGeo.Vector.ByCoordinates(v.X/l, v.Y/l, 0)\r\n\r\ndef dist_pt(a, b):\r\n    return math.sqrt((a.X-b.X)**2 + (a.Y-b.Y)**2)\r\n\r\ndef dist_3d(a, b):\r\n    return math.sqrt((a.X-b.X)**2+(a.Y-b.Y)**2+(a.Z-b.Z)**2)\r\n\r\ndef m_to_ft(m):\r\n    return m / 0.3048\r\n\r\ndef mkpt(x, y, z):\r\n    return DSGeo.Point.ByCoordinates(x, y, z)\r\n\r\ndef proj(pt_a, pt_b, vec):\r\n    return (pt_b.X-pt_a.X)*vec.X + (pt_b.Y-pt_a.Y)*vec.Y\r\n\r\n# ── Inputs ────────────────────────────────────────────────────────────────────\r\nrouting      = IN[0]\r\nsymbol       = unwrap(IN[1])\r\nrodSpacing_m = abs(from_excel(IN[2], idx=1))\r\nnumSystems   = to_int_idx(IN[3], idx=1)\r\nbendRadius_m = abs(from_excel(IN[4], idx=1))\r\nclearance_m  = abs(from_excel(IN[5], idx=1))\r\n\r\nt2_r1        = to_pt(routing[3])\r\nt3_r1        = to_pt(routing[4])\r\nt2_r2        = to_pt(routing[5])\r\nt3_r2        = to_pt(routing[6])\r\nlocalX       = norm_xy(to_vec(routing[7]))\r\nlocalY       = norm_xy(to_vec(routing[8]))\r\ngroundZ_m    = float(routing[9])\r\ncableDia_m   = float(routing[10])\r\nrodBreite_m  = float(routing[11])\r\n\r\nr1_lines     = routing[0]\r\nr2_lines     = routing[1]\r\n\r\ndef line_start(l):\r\n    return to_pt(l.StartPoint)\r\n\r\ndef line_end(l):\r\n    return to_pt(l.EndPoint)\r\n\r\nmv1   = line_start(r1_lines[0])\r\nr1_T1 = line_end(r1_lines[0])\r\nr1_T2 = line_end(r1_lines[1])\r\nr1_T3 = line_end(r1_lines[2])\r\nr1_T4 = line_end(r1_lines[3])\r\nss1   = line_end(r1_lines[-1])\r\n\r\nmv2   = line_start(r2_lines[0])\r\nr2_T1 = line_end(r2_lines[0])\r\nr2_T2 = line_end(r2_lines[1])\r\nr2_T3 = line_end(r2_lines[2])\r\nr2_T4 = line_end(r2_lines[3])\r\nss2   = line_end(r2_lines[-1])\r\n\r\n# ssLen: straight exit length on SS side\r\n# = distance from ss1 to ssStart (line[-2] end = line[-1] start)\r\nssStart1  = line_start(r1_lines[-1])\r\nssStart2  = line_start(r2_lines[-1])\r\nssLen_r1  = dist_pt(ss1, ssStart1)\r\nssLen_r2  = dist_pt(ss2, ssStart2)\r\n\r\n# mvLen: straight exit length on MV side\r\nmvStart1  = line_end(r1_lines[0])   # = T1\r\nmvLen_r1  = dist_pt(mv1, mvStart1)\r\nmvLen_r2  = dist_pt(mv2, line_end(r2_lines[0]))\r\n\r\n# ── Rod height ────────────────────────────────────────────────────────────────\r\nsin60         = math.sqrt(3) / 2.0\r\nrowStep_m     = cableDia_m * (1.0 + sin60) + clearance_m\r\nnumRows       = int(math.ceil(numSystems / 2.0))\r\nlastRow       = numRows - 1\r\n\r\ntopCableTop_m = (groundZ_m\r\n    + cableDia_m / 2.0\r\n    + lastRow * rowStep_m\r\n    + cableDia_m * sin60\r\n    + cableDia_m / 2.0)\r\n\r\nrodHeight_m   = topCableTop_m - groundZ_m\r\n\r\n# ── Rod positions ─────────────────────────────────────────────────────────────\r\n\r\ndef get_rod_positions(t2, t3):\r\n    segLen = dist_pt(t2, t3)\r\n    if segLen < 1e-6:\r\n        return []\r\n\r\n    start_offset = min(2.0 * bendRadius_m, segLen * 0.4)\r\n    end_offset   = min(1.0 * bendRadius_m, segLen * 0.4)\r\n    start_ratio  = start_offset / segLen\r\n    end_ratio    = 1.0 - (end_offset / segLen)\r\n\r\n    p_start = mkpt(\r\n        t2.X + (t3.X - t2.X) * start_ratio,\r\n        t2.Y + (t3.Y - t2.Y) * start_ratio,\r\n        groundZ_m\r\n    )\r\n    p_end = mkpt(\r\n        t2.X + (t3.X - t2.X) * end_ratio,\r\n        t2.Y + (t3.Y - t2.Y) * end_ratio,\r\n        groundZ_m\r\n    )\r\n\r\n    seg = dist_pt(p_start, p_end)\r\n    if seg < 1e-6:\r\n        return [p_start]\r\n\r\n    n_intervals = int(math.ceil(seg / rodSpacing_m)) if rodSpacing_m > 1e-6 else 1\r\n\r\n    positions = []\r\n    for i in range(n_intervals + 1):\r\n        t = i / float(n_intervals)\r\n        positions.append(mkpt(\r\n            p_start.X + (p_end.X - p_start.X) * t,\r\n            p_start.Y + (p_end.Y - p_start.Y) * t,\r\n            groundZ_m\r\n        ))\r\n    return positions\r\n\r\nrod_pos_r1 = get_rod_positions(t2_r1, t3_r1)\r\nrod_pos_r2 = get_rod_positions(t2_r2, t3_r2)\r\n\r\n# ── System offsets on rod ─────────────────────────────────────────────────────\r\nsysBreite_m = 2.0 * cableDia_m\r\nsysOffset_m = rodBreite_m / 2.0 + cableDia_m\r\n\r\ndef get_system_offsets():\r\n    offsets   = []\r\n    remaining = numSystems\r\n    row       = 0\r\n    while remaining > 0:\r\n        z = groundZ_m + cableDia_m / 2.0 + row * rowStep_m\r\n        if remaining >= 2:\r\n            offsets.append((-sysOffset_m, z))\r\n            offsets.append(( sysOffset_m, z))\r\n            remaining -= 2\r\n        else:\r\n            offsets.append((0.0, z))\r\n            remaining -= 1\r\n        row += 1\r\n    return offsets\r\n\r\nsys_offsets = get_system_offsets()\r\n\r\n# ── Face connection grids ─────────────────────────────────────────────────────\r\nnumCols     = max(1, int(math.ceil(math.sqrt(numSystems))))\r\nnumRowsFace = int(math.ceil(numSystems / float(numCols)))\r\nfaceSpacing = cableDia_m + clearance_m\r\ngridW       = (numCols - 1) * faceSpacing\r\ngridH       = (numRowsFace - 1) * faceSpacing\r\n\r\ndef get_face_pts(origin, spread_vec, num):\r\n    pts        = []\r\n    col        = 0\r\n    row        = 0\r\n    col_offset = -gridW / 2.0\r\n    row_offset = -gridH / 2.0\r\n    for i in range(num):\r\n        horiz = col_offset + col * faceSpacing\r\n        vert  = row_offset + row * faceSpacing\r\n        pt = mkpt(\r\n            origin.X + spread_vec.X * horiz,\r\n            origin.Y + spread_vec.Y * horiz,\r\n            origin.Z + vert\r\n        )\r\n        pts.append(pt)\r\n        col += 1\r\n        if col >= numCols:\r\n            col = 0\r\n            row += 1\r\n    return pts\r\n\r\nmv_conn_r1 = get_face_pts(mv1, localX, numSystems)\r\nss_conn_r1 = get_face_pts(ss1, localY, numSystems)\r\nmv_conn_r2 = get_face_pts(mv2, localX, numSystems)\r\nss_conn_r2 = get_face_pts(ss2, localY, numSystems)\r\n\r\n# ── Build path control points ─────────────────────────────────────────────────\r\n# MV exit: -localY by mvLen, then lateral in localX to column\r\n# SS entry: +localX (r1) or -localX (r2) by ssLen from ss_conn,\r\n#           then lateral in localY to match column, then into ss_conn\r\n# This way each ss_conn has its OWN approach segment — no convergence\r\n\r\ndef build_path(mv_conn, ss_conn, x_off, sys_z,\r\n               T1, T2, T3, T4,\r\n               rod_positions,\r\n               mv_len, ss_len, ss_exit_sign):\r\n    \"\"\"\r\n    ss_exit_sign: +1 for r1 (exits +localX), -1 for r2 (exits -localX)\r\n    \"\"\"\r\n    pts = []\r\n\r\n    # A: MV connection\r\n    A = mv_conn\r\n    pts.append(A)\r\n\r\n    # B: exit MV in -localY by mvLen (same for all systems, from their conn pt)\r\n    B = mkpt(\r\n        A.X + localY.X * (-mv_len),\r\n        A.Y + localY.Y * (-mv_len),\r\n        A.Z\r\n    )\r\n    pts.append(B)\r\n\r\n    # C: lateral to sys column at T1 level, keep A.Z\r\n    C = mkpt(T1.X + localX.X * x_off,\r\n             T1.Y + localX.Y * x_off,\r\n             A.Z)\r\n    pts.append(C)\r\n\r\n    # D: T2 column, still at conn Z\r\n    D = mkpt(T2.X + localX.X * x_off,\r\n             T2.Y + localX.Y * x_off,\r\n             A.Z)\r\n    pts.append(D)\r\n\r\n    # E: drop to rod height\r\n    E = mkpt(D.X, D.Y, sys_z)\r\n    pts.append(E)\r\n\r\n    # rod intermediate points\r\n    for rod_pt in rod_positions:\r\n        pts.append(mkpt(\r\n            rod_pt.X + localX.X * x_off,\r\n            rod_pt.Y + localX.Y * x_off,\r\n            sys_z\r\n        ))\r\n\r\n    # F: T3 column at sys_z\r\n    F = mkpt(T3.X + localX.X * x_off,\r\n             T3.Y + localX.Y * x_off,\r\n             sys_z)\r\n    pts.append(F)\r\n\r\n    # G: rise to ss_conn.Z at T3 column\r\n    G = mkpt(F.X, F.Y, ss_conn.Z)\r\n    pts.append(G)\r\n\r\n    # H: lateral in localY to match ss_conn localY position\r\n    # move from G to ss_conn's localY coordinate\r\n    d_y = proj(G, ss_conn, localY)\r\n    H = mkpt(\r\n        G.X + localY.X * d_y,\r\n        G.Y + localY.Y * d_y,\r\n        ss_conn.Z\r\n    )\r\n    pts.append(H)\r\n\r\n    # I: ss_conn moved outward by ssLen in exit direction\r\n    # this is the point ssLen away from ss face in exit direction\r\n    I = mkpt(\r\n        ss_conn.X + localX.X * ss_exit_sign * ss_len,\r\n        ss_conn.Y + localX.Y * ss_exit_sign * ss_len,\r\n        ss_conn.Z\r\n    )\r\n    pts.append(I)\r\n\r\n    # J: SS connection\r\n    pts.append(ss_conn)\r\n\r\n    return pts\r\n\r\ndef make_nurbs(ctrl_pts):\r\n    clean = [ctrl_pts[0]]\r\n    for p in ctrl_pts[1:]:\r\n        prev = clean[-1]\r\n        if dist_3d(p, prev) > 1e-4:\r\n            clean.append(p)\r\n    if len(clean) < 2:\r\n        return None\r\n    try:\r\n        deg = min(3, len(clean) - 1)\r\n        return DSGeo.NurbsCurve.ByControlPoints(clean, deg)\r\n    except:\r\n        return None\r\n\r\n# ── Build curves ──────────────────────────────────────────────────────────────\r\nsys_curves_r1 = []\r\nsys_curves_r2 = []\r\ndebug_errors  = []\r\n\r\nfor i, (x_off, z) in enumerate(sys_offsets):\r\n    try:\r\n        ctrl1 = build_path(\r\n            mv_conn_r1[i], ss_conn_r1[i],\r\n            x_off, z,\r\n            r1_T1, r1_T2, r1_T3, r1_T4,\r\n            rod_pos_r1,\r\n            mvLen_r1, ssLen_r1, +1\r\n        )\r\n        c1 = make_nurbs(ctrl1)\r\n        sys_curves_r1.append(c1)\r\n        if not c1:\r\n            debug_errors.append(\"r1 sys{} nurbs failed, {} pts\".format(i, len(ctrl1)))\r\n    except Exception as e:\r\n        sys_curves_r1.append(None)\r\n        debug_errors.append(\"r1 sys{} error: {}\".format(i, str(e)))\r\n\r\n    try:\r\n        ctrl2 = build_path(\r\n            mv_conn_r2[i], ss_conn_r2[i],\r\n            x_off, z,\r\n            r2_T1, r2_T2, r2_T3, r2_T4,\r\n            rod_pos_r2,\r\n            mvLen_r2, ssLen_r2, -1\r\n        )\r\n        c2 = make_nurbs(ctrl2)\r\n        sys_curves_r2.append(c2)\r\n        if not c2:\r\n            debug_errors.append(\"r2 sys{} nurbs failed, {} pts\".format(i, len(ctrl2)))\r\n    except Exception as e:\r\n        sys_curves_r2.append(None)\r\n        debug_errors.append(\"r2 sys{} error: {}\".format(i, str(e)))\r\n\r\n# ── Place rods ────────────────────────────────────────────────────────────────\r\n\r\ndef place_rods(positions, sym, height_m):\r\n    placed = []\r\n    if hasattr(sym, 'InternalElement'):\r\n        sym = sym.InternalElement\r\n    angle = math.atan2(localX.Y, localX.X)\r\n\r\n    TransactionManager.Instance.EnsureInTransaction(doc)\r\n    if not sym.IsActive:\r\n        sym.Activate()\r\n        doc.Regenerate()\r\n    TransactionManager.Instance.TransactionTaskDone()\r\n\r\n    TransactionManager.Instance.EnsureInTransaction(doc)\r\n    for pt in positions:\r\n        revit_pt = XYZ(m_to_ft(pt.X), m_to_ft(pt.Y), m_to_ft(groundZ_m))\r\n        inst = doc.Create.NewFamilyInstance(\r\n            revit_pt, sym,\r\n            Structure.StructuralType.NonStructural\r\n        )\r\n        loc = inst.Location\r\n        if hasattr(loc, 'Point'):\r\n            current_z = loc.Point.Z\r\n            target_z  = m_to_ft(groundZ_m)\r\n            if abs(current_z - target_z) > 1e-6:\r\n                loc.Move(XYZ(0, 0, target_z - current_z))\r\n\r\n        for pname in [\"Offset\", \"Höhenversatz\", \"Elevation\", \"Höhe von Ebene\"]:\r\n            p = inst.LookupParameter(pname)\r\n            if p and not p.IsReadOnly and p.StorageType == StorageType.Double:\r\n                p.Set(0.0)\r\n                break\r\n\r\n        if abs(angle) > 1e-6:\r\n            placed_z = inst.Location.Point.Z\r\n            axis = Line.CreateBound(\r\n                XYZ(revit_pt.X, revit_pt.Y, placed_z),\r\n                XYZ(revit_pt.X, revit_pt.Y, placed_z + 1)\r\n            )\r\n            ElementTransformUtils.RotateElement(doc, inst.Id, axis, angle)\r\n\r\n        for pname in [\"Hoehe\", \"Höhe\", \"Height\", \"Laenge\", \"Länge\", \"Length\"]:\r\n            p = inst.LookupParameter(pname)\r\n            if p and not p.IsReadOnly:\r\n                p.Set(m_to_ft(height_m))\r\n                break\r\n        placed.append(inst)\r\n    TransactionManager.Instance.TransactionTaskDone()\r\n    return placed\r\n\r\nplaced_r1 = place_rods(rod_pos_r1, symbol, rodHeight_m)\r\nplaced_r2 = place_rods(rod_pos_r2, symbol, rodHeight_m)\r\n\r\n# ── System group points ───────────────────────────────────────────────────────\r\n\r\ndef all_system_pts(rod_positions):\r\n    all_pts = []\r\n    for rodPt in rod_positions:\r\n        row_pts = []\r\n        for (x_off, z) in sys_offsets:\r\n            pt = mkpt(\r\n                rodPt.X + localX.X * x_off,\r\n                rodPt.Y + localX.Y * x_off,\r\n                z\r\n            )\r\n            row_pts.append(pt)\r\n        all_pts.append(row_pts)\r\n    return all_pts\r\n\r\nsys_pts_r1 = all_system_pts(rod_pos_r1)\r\nsys_pts_r2 = all_system_pts(rod_pos_r2)\r\n\r\n# ── Output ────────────────────────────────────────────────────────────────────\r\nOUT = (\r\n    placed_r1,\r\n    placed_r2,\r\n    sys_curves_r1,\r\n    sys_curves_r2,\r\n    sys_pts_r1,\r\n    sys_pts_r2,\r\n    mv_conn_r1,\r\n    ss_conn_r1,\r\n    mv_conn_r2,\r\n    ss_conn_r2,\r\n    debug_errors,\r\n    {\r\n        \"numSystems\":    numSystems,\r\n        \"numCurves_r1\":  len([c for c in sys_curves_r1 if c]),\r\n        \"numCurves_r2\":  len([c for c in sys_curves_r2 if c]),\r\n        \"numRods_r1\":    len(rod_pos_r1),\r\n        \"numRods_r2\":    len(rod_pos_r2),\r\n        \"numErrors\":     len(debug_errors),\r\n        \"rodHeight_m\":   round(rodHeight_m,  4),\r\n        \"sysOffset_m\":   round(sysOffset_m,  4),\r\n        \"rowStep_m\":     round(rowStep_m,    4),\r\n        \"faceSpacing_m\": round(faceSpacing,  4),\r\n        \"ssLen_r1\":      round(ssLen_r1,     4),\r\n        \"ssLen_r2\":      round(ssLen_r2,     4),\r\n        \"mvLen_r1\":      round(mvLen_r1,     4),\r\n        \"rodSpacing_m\":  round(rodSpacing_m, 4),\r\n        \"bendRadius_m\":  round(bendRadius_m, 4),\r\n        \"clearance_m\":   round(clearance_m,  4),\r\n        \"groundZ_m\":     round(groundZ_m,    4),\r\n        \"cableDia_m\":    round(cableDia_m,   4),\r\n        \"gridW_m\":       round(gridW,        4),\r\n        \"gridH_m\":       round(gridH,        4),\r\n    }\r\n)",
      "Engine": "CPython3",
