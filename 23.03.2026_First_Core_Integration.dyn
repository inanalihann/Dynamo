    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Vector\r\n\r\ndef first(x):\r\n    while isinstance(x, list) and len(x) == 1:\r\n        x = x[0]\r\n    return x\r\n\r\nrefPt = first(IN[0])                 # one family base point\r\nelem  = UnwrapElement(first(IN[1]))  # family instance\r\nux    = first(IN[2])                 # real local X\r\ng     = first(IN[3])                 # guide direction\r\n\r\ndef get_param(e, name):\r\n    # instance parameter\r\n    p = e.LookupParameter(name)\r\n    if p:\r\n        return p.AsDouble()\r\n\r\n    # type parameter\r\n    try:\r\n        t = e.Symbol\r\n        if t:\r\n            p = t.LookupParameter(name)\r\n            if p:\r\n                return p.AsDouble()\r\n    except:\r\n        pass\r\n\r\n    return None\r\n\r\ndef build_local_y(localX, guide):\r\n    py_x = -localX.Y\r\n    py_y =  localX.X\r\n    dot = py_x * guide.X + py_y * guide.Y\r\n    if dot < 0:\r\n        py_x = -py_x\r\n        py_y = -py_y\r\n    return Vector.ByCoordinates(py_x, py_y, 0)\r\n\r\ndef make_point(basePt, localX, localY, xVal, yVal, zVal):\r\n    move = localX.Scale(xVal).Add(localY.Scale(yVal)).Add(Vector.ByCoordinates(0, 0, 1).Scale(zVal))\r\n    return basePt.Add(move)\r\n\r\n# raw values from Revit = feet\r\nx1_raw = get_param(elem, \"Cable_X1\")\r\ny1_raw = get_param(elem, \"Cable_Y1\")\r\nz1_raw = get_param(elem, \"Cable_Z1\")\r\n\r\nx2_raw = get_param(elem, \"Cable_X2\")\r\ny2_raw = get_param(elem, \"Cable_Y2\")\r\nz2_raw = get_param(elem, \"Cable_Z2\")\r\n\r\nmissing = []\r\nfor n, v in [(\"Cable_X1\", x1_raw), (\"Cable_Y1\", y1_raw), (\"Cable_Z1\", z1_raw),\r\n             (\"Cable_X2\", x2_raw), (\"Cable_Y2\", y2_raw), (\"Cable_Z2\", z2_raw)]:\r\n    if v is None:\r\n        missing.append(n)\r\n\r\nux_len = (ux.X**2 + ux.Y**2) ** 0.5\r\n\r\nif ux_len == 0:\r\n    OUT = \"Error: local X vector length is zero.\"\r\nelif missing:\r\n    OUT = \"Missing parameters: \" + \", \".join(missing)\r\nelse:\r\n    # feet -> meters\r\n    x1 = x1_raw * 0.3048\r\n    y1 = y1_raw * 0.3048\r\n    z1 = z1_raw * 0.3048\r\n\r\n    x2 = x2_raw * 0.3048\r\n    y2 = y2_raw * 0.3048\r\n    z2 = z2_raw * 0.3048\r\n\r\n    localX = Vector.ByCoordinates(ux.X / ux_len, ux.Y / ux_len, 0)\r\n    localY = build_local_y(localX, g)\r\n\r\n    pt1 = make_point(refPt, localX, localY, x1, y1, z1)\r\n    pt2 = make_point(refPt, localX, localY, x2, y2, z2)\r\n\r\n    OUT = pt1, pt2, [x1, y1, z1], [x2, y2, z2]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "b97b15e8d48646039126869350ac0149",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "28146793b5f44bc19d9f924f2467b30c",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
